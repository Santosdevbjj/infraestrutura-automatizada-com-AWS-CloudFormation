###############################################################################
#
# Projeto
#
# Implementando Infraestrutura Automatizada com AWS CloudFormation
#
# Arquivo:
# .gitignore
#
# Objetivo:
#
# Evitar o versionamento de arquivos temporários, artefatos de build,
# logs, credenciais locais e arquivos gerados automaticamente durante
# validação e deployment.
#
###############################################################################

###############################################################################
# Sistema Operacional
###############################################################################

.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

Thumbs.db
Desktop.ini

###############################################################################
# Editores
###############################################################################

.vscode/
.idea/

*.code-workspace

*.swp
*.swo
*~

###############################################################################
# Python
###############################################################################

__pycache__/

*.pyc
*.pyo
*.pyd

.pytest_cache/

.mypy_cache/

.ruff_cache/

.venv/
venv/
env/

###############################################################################
# Logs
###############################################################################

logs/

*.log

*.out

*.err

*.trace

###############################################################################
# Relatórios
###############################################################################

reports/

coverage/

htmlcov/

coverage.xml

###############################################################################
# Artefatos
###############################################################################

artifacts/

tmp/

temp/

.cache/

dist/

build/

###############################################################################
# CloudFormation
###############################################################################

packaged-template.yaml

packaged.yml

template-export.yaml

change-set.json

stack-events.json

stack-outputs.json

stack-resources.json

validation-report.json

deployment-report.json

###############################################################################
# AWS CLI
###############################################################################

.aws-sam/

samconfig.toml

###############################################################################
# Terraform
###############################################################################

.terraform/

terraform.tfstate

terraform.tfstate.backup

*.tfplan

###############################################################################
# Shell Scripts
###############################################################################

*.pid

*.seed

*.bak

###############################################################################
# Credenciais
###############################################################################

.env

.env.*

*.pem

*.key

*.crt

*.csr

credentials

secrets.yml

secret.yml

###############################################################################
# AWS Credentials
###############################################################################

.aws/

###############################################################################
# GitHub Actions
###############################################################################

.github/*.local

.github/**/*.local

###############################################################################
# Backup
###############################################################################

backup/

backups/

*.backup

*.old

###############################################################################
# Arquivos Compactados
###############################################################################

*.zip

*.tar

*.gz

*.tgz

*.rar

###############################################################################
# Banco de Dados
###############################################################################

*.db

*.sqlite

*.sqlite3

###############################################################################
# Testes
###############################################################################

pytestdebug.log

nosetests.xml

###############################################################################
# Arquivos Temporários
###############################################################################

*.tmp

*.temp

*.cache

*.lock

###############################################################################
# Diretórios Gerados
###############################################################################

output/

exports/

generated/

generated-files/

###############################################################################
# Mantidos no Repositório
###############################################################################
#
# README.md
# LICENSE
# docs/
# templates/
# scripts/
# .github/
#
###############################################################################
#
# Boas Práticas
#
# ✔ Não versionar credenciais
# ✔ Não versionar logs
# ✔ Não versionar artefatos temporários
# ✔ Não versionar arquivos de sistema
# ✔ Manter apenas código-fonte e documentação
#
